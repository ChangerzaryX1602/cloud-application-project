# Zitadel API URL (your Zitadel instance)
ZITADEL_API_URL=https://zitadel:8080

# Service user token (will be mounted from login-client.pat)
ZITADEL_SERVICE_USER_TOKEN=

# Optional: File path for token (alternative to ZITADEL_SERVICE_USER_TOKEN)
ZITADEL_SERVICE_USER_TOKEN_FILE=/app/pat/login-client.pat

# Base path for the login UI
NEXT_PUBLIC_BASE_PATH=/ui/v2/login

# Application name shown in emails
NEXT_PUBLIC_APPLICATION_NAME=KKU Cloud Application Project SSO

# Debug mode
DEBUG=false
