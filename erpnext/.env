# ERPNext Configuration
# Generate secure passwords with: openssl rand -hex 32

# Database (reuse existing PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=erpnext
DB_USER=erpnext
DB_PASSWORD=ChangeMe123!

# Site configuration
FRAPPE_SITE_NAME=erpnext.mysterchat.com
ERPNEXT_SITE_NAME=erpnext.mysterchat.com
LETS_ENCRYPT_DOMAIN=erpnext.mysterchat.com

# Redis (shared queue/cache/socketio)
REDIS_QUEUE=redis://erpnext-redis:6379
REDIS_CACHE=redis://erpnext-redis:6379
REDIS_SOCKETIO=redis://erpnext-redis:6379
SOCKETIO_PORT=9000

# Admin user (for initial setup)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe123!

# Migration settings
AUTO_MIGRATE=1
MAINTENANCE_MODE=0
